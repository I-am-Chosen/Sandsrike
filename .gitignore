# ─── Unity ───────────────────────────────────────────────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emory[Cc]aptures/
[Rr]ecordings/

# Asset meta files are required for proper Unity function
!/[Aa]ssets/**/*.meta

# Unity autogenerated
*.pidb.meta
*.pdb.meta
*.mdb.meta
/[Aa]ssets/[Aa]sset[Ss]tore-5.x/

# Unity crash reports
sysinfo.txt
*.stackdump

# ─── Server Build ─────────────────────────────────────────────────────────────
# Track only the placeholder marker; the actual binary is produced by CI
ServerBuild/*
!ServerBuild/.gitkeep

# ─── Visual Studio / Rider ───────────────────────────────────────────────────
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db
ExportedObj/

# ─── JetBrains Rider ──────────────────────────────────────────────────────────
.idea/
*.sln.iml

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── Node / npm (if any tooling) ─────────────────────────────────────────────
node_modules/
npm-debug.log*

# ─── Secrets (never commit) ──────────────────────────────────────────────────
*.env
.env.*
secrets.json
